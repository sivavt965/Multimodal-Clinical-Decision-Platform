# =============================================================================
# backend/.env.example — copy to backend/.env and fill in your values
# =============================================================================

# Supabase project — Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (publishable) key — sent to browser, gated by RLS
SUPABASE_KEY=eyJhbGciOi...

# Service-role key — used server-side; bypasses RLS. NEVER ship to browser.
# The FastAPI backend prefers this when present.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Storage bucket names (create in Supabase Dashboard → Storage)
SUPABASE_CXR_BUCKET=cxr-images
SUPABASE_HEATMAP_BUCKET=heatmaps

# DenseNet121 weights for CXR inference (773 MB checkpoint)
# Download from PhysioNet MIMIC-CXR-JPG and place at this path:
CXR_WEIGHTS_PATH=/absolute/path/to/mimic_project/models/baseline_best.pt
