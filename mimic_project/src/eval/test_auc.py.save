import torch
import numpy as np
from sklearn.metrics import roc_auc_score

from src.utils.device import get_device        # adjust if needed

LABEL_NAMES = [
    "Atelectasis", "Cardiomegaly", "Consolidation", "Edema",
    "Enlarged Cardiomediastinum", "Fracture",
    "Lung Opacity", "Pleural Effusion"
]

@torch.no_grad()
def evaluate(model, loader, device):
    model.eval()
    ys, ps = [], []

    for images, targets in loader:
        images = images.to(device, non_blocking=True)
        targets = targets.to(device).float()

        logits = model(images)
        probs = torch.sigmoid(logits)

        ps.append(probs.cpu())
        ys.append(targets.cpu())

    y_true = torch.cat(ys).numpy()
    y_prob = torch.cat(ps).numpy()

    per_label_auc = []
    for i in range(y_true.shape[1]):
        if len(np.unique(y_true[:, i])) < 2:
            per_label_auc.append(np.nan)
        else:
            per_label_auc.append(
                roc_auc_score(y_true[:, i], y_prob[:, i])
            )

    macro_auc = float(np.nanmean(per_label_auc))
    micro_auc = float(roc_auc_score(y_true.ravel(), y_prob.ravel()))

    return per_label_auc, macro_auc, micro_auc


def main():
    device = get_device()

    model = build_model(num_classes=8).to(device)
    ckpt = torch.load("models/baseline_best.pt", map_location=device)
    model.load_state_dict(ckpt["model"] if "model" in ckpt else ckpt)

    test_loader = get_test_loader()

    per_label_auc, macro_auc, micro_auc = evaluate(
        model, test_loader, device
    )

    print("\n=== TEST ROC-AUC ===")
    for name, auc in zip(LABEL_NAMES, per_label_auc):
        print(f"{name:28s}: {auc:.4f}")

    print(f"\nMacro AUC: {macro_auc:.4f}")
    print(f"Micro AUC: {micro_auc:.4f}")


if __name__ == "__main__":
    main()
