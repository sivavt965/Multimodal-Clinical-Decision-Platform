import torch
import torch.nn as nn
from torchvision.models import densenet121, DenseNet121_Weights


class DenseNet121(nn.Module):
    def __init__(self, num_classes: int, pretrained: bool = True, dropout_p: float = 0.2):
        super().__init__()
        if pretrained:
            weights = DenseNet121_Weights.IMAGENET1K_V1
            backbone = densenet121(weights=weights)
        else:
            backbone = densenet121(weights=None)

        in_features = backbone.classifier.in_features
        backbone.classifier = nn.Identity()

        self.backbone = backbone
        self.dropout = nn.Dropout(p=dropout_p)
        self.classifier = nn.Linear(in_features, num_classes)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        feats = self.backbone(x)
        feats = self.dropout(feats)
        return self.classifier(feats)


def build_densenet121(num_classes: int, pretrained: bool = True, dropout_p: float = 0.2) -> nn.Module:
    return DenseNet121(num_classes=num_classes, pretrained=pretrained, dropout_p=dropout_p)
